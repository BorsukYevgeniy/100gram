model Chat {
  id          Int     @id @default(autoincrement())
  avatar      String?
  title       String?
  description String?

  messages    Message[]
  chatToUsers ChatToUser[]

  chatType   ChatType
  visibility Visibility @default(PRIVATE)

  membersCount Int     @default(1)
  inviteToken  String? @unique

  ownerId Int?
  owner   User? @relation(fields: [ownerId], references: [id])

  /**
   * Private chats dont have owner, avatar, inviteToken, title and description.
   * He's visibility is private by default and cant be changed.
   */
}

enum ChatType {
  PRIVATE
  GROUP
  CHANNEL
}

enum Visibility {
  PUBLIC
  PRIVATE
}
